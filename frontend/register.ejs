<%- include('./includes/head'); %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-4 font-jakarta">

    <a href="/Hot-Stay" class="absolute top-5 left-5 text-text font-semibold text-sm hover:text-primary transition-colors flex items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <div class="bg-white w-full max-w-md p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
        <div class="text-center mb-6">
            <%- include('./includes/logo'); %>
        </div>

        <h2 class="text-2xl font-bold text-center mb-2">Create account</h2>
        <p class="text-gray-600 text-sm text-center mb-6">Sign up to start booking stays.</p>

        <form id="registerForm" action="/register" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Full name</label>
                <input type="text" name="name" placeholder="Full name" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Email</label>
                <input type="email" name="email" placeholder="Email" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Phone</label>
                <input type="tel" name="phone" placeholder="Phone number"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Password</label>
                <input type="password" id="password" name="password" placeholder="Password" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Confirm password</label>
                <input type="password" id="confirmPassword" placeholder="Confirm password" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <button type="submit" class="w-full bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 rounded-lg transition-colors">
                Create account
            </button>
        </form>

        <p class="text-center mt-6 text-sm">
            Already have an account?
            <a href="/Hot-Stay/login" class="text-text font-semibold hover:text-primary transition-colors">Log in</a>
        </p>
    </div>

    <script>
        gsap.from(".bg-white", {
            duration: 0.35,
            y: 15,
            opacity: 0,
            ease: "power4.out"
        });

        document.getElementById('registerForm').addEventListener('submit', (e) => {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (password !== confirmPassword) {
                e.preventDefault();
                alert('Passwords do not match.');
                return;
            }

            const btn = document.querySelector('button[type="submit"]');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Creating account...';
            btn.disabled = true;
        });
    </script>

</body>
</html>
