<%- include('./includes/head'); %>
        </head>

        <body class="bg-background font-jakarta text-text min-h-screen">

            <!-- Navigation -->
            <nav class="sticky top-0 bg-white/98 backdrop-blur-sm border-b border-gray-200 z-50">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="flex justify-between items-center h-16">
                        <%- include('./includes/logo'); %>

                        <div
                            class="hidden md:flex items-center bg-white border border-gray-300 rounded-full px-6 py-2 shadow-sm hover:shadow-md transition-shadow cursor-pointer">
                            <div class="px-4 text-sm font-semibold border-r border-gray-300">Anywhere</div>
                            <div class="px-4 text-sm font-semibold border-r border-gray-300">Any week</div>
                            <div class="px-4 text-sm font-semibold">Add guests</div>
                        </div>

                        <%- include('./includes/profile icon'); %>
                    </div>
            </nav>
            <!-- Sidebar Categories -->
            <div class="h-screen w-[10%] bg-gray-50 border-r border-gray-200 fixed left-0 top-0 mt-16">

                <div class="flex flex-col gap-6 p-4 overflow-y-auto h-full">

                    <!-- Item -->
                    <a href="/Hot-Stay/home?category=Castles" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Castles' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🏰</span>
                        <span class="text-xs font-semibold text-center">Castles</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Beachfront" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Beachfront' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🏖️</span>
                        <span class="text-xs font-semibold text-center">Beachfront</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Amazing views" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Amazing views' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🏔️</span>
                        <span class="text-xs font-semibold text-center">Amazing views</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Trending" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Trending' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🔥</span>
                        <span class="text-xs font-semibold text-center">Trending</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Design" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Design' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🎨</span>
                        <span class="text-xs font-semibold text-center">Design</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Golfing" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Golfing' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">⛳</span>
                        <span class="text-xs font-semibold text-center">Golfing</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Vineyards" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Vineyards' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🍷</span>
                        <span class="text-xs font-semibold text-center">Vineyards</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Arctic" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Arctic' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">❄️</span>
                        <span class="text-xs font-semibold text-center">Arctic</span>
                    </a>

                    <a href="/Hot-Stay/home?category=Desert" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= selectedCategory === 'Desert' ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">🌵</span>
                        <span class="text-xs font-semibold text-center">Desert</span>
                    </a>

                    <a href="/Hot-Stay/home" class="flex flex-col items-center gap-2 cursor-pointer border-l-4 <%= !selectedCategory ? 'border-primary' : 'border-transparent hover:border-gray-300' %> pl-2 transition-colors">
                        <span class="text-2xl">⛵</span>
                        <span class="text-xs font-semibold text-center">All Hotels</span>
                    </a>

                </div>
            </div>

            <!-- Main Content -->
            <main class="max-w-7xl mx-auto px-4 sm:px-6 ml-4 lg:px-8 py-8 ml-[10%]">
                
                <!-- Search Section -->
                <div class="bg-white rounded-xl shadow-md p-6 mb-8 border border-gray-200">
                    <form method="GET" action="/Hot-Stay/home" class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
                            <!-- Location -->
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-text">Location</label>
                                <input type="text" name="location" placeholder="City or region" value="<%= searchFilters && searchFilters.location ? searchFilters.location : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-primary outline-none" />
                            </div>

                            <!-- Property Type -->
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-text">Property Type</label>
                                <select name="type" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-primary outline-none">
                                    <option value="">All Types</option>
                                    <% if(propertyTypes && propertyTypes.length > 0) { %>
                                        <% propertyTypes.forEach(type => { %>
                                            <option value="<%= type %>" <%= searchFilters && searchFilters.type === type ? 'selected' : '' %>>
                                                <%= type %>
                                            </option>
                                        <% }) %>
                                    <% } %>
                                </select>
                            </div>

                            <!-- Check-in Date -->
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-text">Check-in</label>
                                <input type="date" name="checkin" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-primary outline-none" />
                            </div>

                            <!-- Check-out Date -->
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-text">Check-out</label>
                                <input type="date" name="checkout" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-primary outline-none" />
                            </div>

                            <!-- Number of Guests -->
                            <div>
                                <label class="block text-sm font-semibold mb-2 text-text">Guests</label>
                                <select name="guests" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:border-primary outline-none">
                                    <option value="">Any</option>
                                    <option value="1" <%= searchFilters && searchFilters.guests === '1' ? 'selected' : '' %>>1 Guest</option>
                                    <option value="2" <%= searchFilters && searchFilters.guests === '2' ? 'selected' : '' %>>2 Guests</option>
                                    <option value="3" <%= searchFilters && searchFilters.guests === '3' ? 'selected' : '' %>>3 Guests</option>
                                    <option value="4" <%= searchFilters && searchFilters.guests === '4' ? 'selected' : '' %>>4 Guests</option>
                                    <option value="5" <%= searchFilters && searchFilters.guests === '5' ? 'selected' : '' %>>5+ Guests</option>
                                </select>
                            </div>

                            <!-- Search Button -->
                            <div class="flex items-end">
                                <button type="submit" class="w-full bg-secondary hover:bg-secondary/90 text-white font-semibold py-2 rounded-lg transition-colors">
                                    Search
                                </button>
                            </div>
                        </div>

                        <!-- Keep category filter if present -->
                        <% if(selectedCategory) { %>
                            <input type="hidden" name="category" value="<%= selectedCategory %>" />
                        <% } %>
                    </form>
                </div>

                <% if(selectedCategory) { %>
                    <h2 class="text-2xl font-bold mb-6 text-text"><%= selectedCategory %></h2>
                <% } %>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 ml-12 xl:grid-cols-4 gap-6">
                    <% if(hotels && hotels.length > 0) { %>
                        <% hotels.forEach(hotel => { %>
                            <a href="/Hot-Stay/booking/<%= hotel.id %>" class="group block">
                                <div class="relative aspect-square rounded-xl overflow-hidden bg-gray-200 mb-3">
                                    <% if(hotel.images && hotel.images.length > 0) { %>
                                        <img src="<%= hotel.images[0] %>" alt="<%= hotel.name %>"
                                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                                    <% } else { %>
                                        <div class="w-full h-full bg-gradient-to-br from-primary/20 to-primary/40">
                                        </div>
                                    <% } %>
                                    <button
                                        class="absolute top-3 right-3 p-2 bg-white/80 backdrop-blur-sm rounded-full text-gray-600 hover:text-red-500 transition-colors">
                                        <i class="fa-regular fa-heart"></i>
                                    </button>
                                </div>

                                <div class="space-y-1">
                                    <div class="flex justify-between items-start">
                                        <h3 class="font-semibold text-sm text-text">
                                            <%= hotel.location %>
                                        </h3>
                                        <div class="flex items-center gap-1">
                                            <i class="fa-solid fa-star text-xs text-yellow-500"></i>
                                            <span class="text-sm">
                                                <%= hotel.rating %>
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text-gray-500 text-sm">
                                        <%= hotel.host %>
                                    </p>
                                    <p class="text-gray-500 text-sm">Available Oct 12 – 17</p>
                                    <p class="text-sm">
                                        <span class="font-semibold">₹<%= hotel.price %></span>
                                        <span class="font-normal">/ night</span>
                                    </p>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full text-center py-12">
                            <p class="text-gray-500 text-lg">No hotels found in this category.</p>
                            <a href="/Hot-Stay/home" class="text-primary hover:text-primary/80 font-semibold mt-4 inline-block">View all hotels</a>
                        </div>
                    <% } %>
                </div>
            </main>

            <!-- Map Button -->
            <div
                class="fixed bottom-8 left-1/2 transform -translate-x-1/2 bg-dark text-white px-6 py-3 rounded-full font-semibold flex items-center gap-2 shadow-lg hover:bg-black transition-colors cursor-pointer z-40">
                Show Map
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                </svg>
            </div>

            <!-- Footer -->
            <footer class="bg-gray-50 border-t border-gray-200 mt-16 ml-[10%]">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
                        <div>
                            <h4 class="font-semibold text-sm mb-4">Support</h4>
                            <div class="space-y-2 text-sm text-gray-600">
                                <p>Help Centre</p>
                                <p>HotStay Cover</p>
                                <p>Anti-discrimination</p>
                                <p>Disability support</p>
                            </div>
                        </div>
                        <div>
                            <h4 class="font-semibold text-sm mb-4">Hosting</h4>
                            <div class="space-y-2 text-sm text-gray-600">
                                <p>HotStay your home</p>
                                <p>Cover for Hosts</p>
                                <p>Hosting resources</p>
                                <p>Community forum</p>
                            </div>
                        </div>
                        <div>
                            <h4 class="font-semibold text-sm mb-4">About</h4>
                            <div class="space-y-2 text-sm text-gray-600">
                                <p>Newsroom</p>
                                <p>New features</p>
                                <p>Careers</p>
                                <p>Investors</p>
                            </div>
                        </div>
                    </div>
                    <div
                        class="border-t border-gray-200 pt-6 flex flex-col sm:flex-row justify-between items-center text-sm text-gray-600">
                        <div>© 2026 HotStay, Inc. · Privacy · Terms · Sitemap</div>
                        <div class="mt-2 sm:mt-0">English (GB) · USD · $</div>
                    </div>
                </div>
            </footer>

        </body>

        </html>