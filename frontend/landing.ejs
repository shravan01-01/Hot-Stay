          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 text-secondary text-xl">
            <i class="fa-solid fa-headset"></i>
          </div>
          <h3 class="text-xl font-semibold mb-2">Live support</h3>
          <p class="text-sm text-gray-600">Our team is here for you before, during, and after your stay.</p>
        </div>
        <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 text-secondary text-xl">
            <i class="fa-solid fa-calendar-check"></i>
