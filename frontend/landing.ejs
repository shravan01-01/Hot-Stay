          <a href="#about" class="text-text hover:text-primary transition-colors font-medium">About</a>
          <a href="#categories" class="text-text hover:text-primary transition-colors font-medium">Categories</a>
          <a href="#how-it-works" class="text-text hover:text-primary transition-colors font-medium">How it works</a>
          <a href="/Hot-Stay/login" class="border-2 border-primary text-primary hover:bg-primary hover:text-white px-4 py-2 rounded-md font-medium transition-colors">Login</a>
