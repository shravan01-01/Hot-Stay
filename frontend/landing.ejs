            <h3 class="text-2xl font-semibold mt-3">Fast confirmation</h3>
            <p class="mt-2 text-sm text-gray-200/80">Reserve with confidence through secure checkout and flexible cancellation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

