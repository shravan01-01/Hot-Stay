    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-sm uppercase tracking-[0.3em] text-secondary font-semibold">Why travelers choose HotStay</p>
        <h2 class="text-3xl sm:text-4xl font-bold mt-4 text-text">A better way to book stays</h2>
        <p class="mt-4 max-w-2xl mx-auto text-gray-600">Enjoy expert-picked accommodations, clear terms, and personalized travel support for every visit.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 text-secondary text-xl">
            <i class="fa-solid fa-star"></i>
          </div>
          <h3 class="text-xl font-semibold mb-2">Top-rated stays</h3>
          <p class="text-sm text-gray-600">Discover high-rated properties with real guest reviews and accurate photos.</p>
        </div>
        <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4 text-secondary text-xl">
            <i class="fa-solid fa-wallet"></i>
          </div>
