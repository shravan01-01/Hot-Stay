        </div>
        <div class="space-y-6">
          <div class="flex gap-4 items-start rounded-3xl border border-gray-200 bg-slate-50 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-secondary text-white text-lg font-bold">1</div>
            <div>
              <h3 class="text-xl font-semibold">Search curated stays</h3>
              <p class="mt-2 text-gray-600 text-sm">Browse handpicked homes, hotels, and retreats by destination, price, and amenities.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start rounded-3xl border border-gray-200 bg-slate-50 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-secondary text-white text-lg font-bold">2</div>
            <div>
              <h3 class="text-xl font-semibold">Reserve with confidence</h3>
              <p class="mt-2 text-gray-600 text-sm">Complete a secure booking and review the exact stay details before you confirm.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start rounded-3xl border border-gray-200 bg-slate-50 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-secondary text-white text-lg font-bold">3</div>
            <div>
              <h3 class="text-xl font-semibold">Enjoy your trip</h3>
              <p class="mt-2 text-gray-600 text-sm">Arrive knowing everything is ready, with help available from check-in to checkout.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

