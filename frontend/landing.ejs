<!DOCTYPE html>
<html lang="en">
<%- include('./includes/head'); %>
</head>
<body class="bg-background font-jakarta text-text">

  <!-- Navigation -->
  <header class="h-16 bg-white/95 backdrop-blur-sm border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-full">
        <a href="#" class="text-primary text-xl font-bold">HotStay</a>
        <nav class="flex items-center gap-6">
          <a href="#about" class="text-text hover:text-primary transition-colors font-medium">About Us</a>
          <a href="/Hot-Stay/login" class="border-2 border-primary text-primary hover:bg-primary hover:text-white px-4 py-2 rounded-md font-medium transition-colors">Login</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative py-20 lg:py-32 bg-gradient-to-r from-dark/80 to-dark/60 text-white">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=1920&q=80');"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h1 class="text-4xl lg:text-6xl font-bold leading-tight">
            Book Better,<br>Travel Simpler.
          </h1>
          <p class="text-lg lg:text-xl text-gray-200 max-w-md">
            Verified stays with transparent pricing. Join 50k+ travelers exploring the world with HotStay.
          </p>
          <a href="/Hot-Stay/home" class="inline-block bg-secondary hover:bg-secondary/90 text-white font-semibold px-6 py-3 rounded-md transition-colors">
            Start Exploring
          </a>
        </div>
        <div class="hidden lg:block">
          <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=800&q=80"
               alt="Luxury Hotel"
               class="w-full h-80 object-cover rounded-xl shadow-2xl">
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-background" id="about">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12 text-text">Why Travelers Trust Us</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl border border-gray-200 hover:shadow-lg hover:border-primary transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <i class="fa-solid fa-shield-alt text-accent text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-text">Vetted Listings</h3>
          <p class="text-gray-600 text-sm">Every home is hand-verified for quality, safety, and high-speed Wi-Fi standards.</p>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200 hover:shadow-lg hover:border-primary transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <i class="fa-solid fa-tags text-accent text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-text">Best Rates</h3>
          <p class="text-gray-600 text-sm">Direct partnerships with hosts mean you save up to 15% compared to other platforms.</p>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200 hover:shadow-lg hover:border-primary transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <i class="fa-solid fa-headset text-accent text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-text">24/7 Support</h3>
          <p class="text-gray-600 text-sm">Not a bot. A real human team is ready to help you via chat, anytime, anywhere.</p>
        </div>

        <div class="bg-white p-6 rounded-xl border border-gray-200 hover:shadow-lg hover:border-primary transition-all group">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
            <i class="fa-solid fa-undo text-accent text-xl"></i>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-text">Easy Returns</h3>
          <p class="text-gray-600 text-sm">Plans change. Enjoy flexible cancellation options on over 80% of our properties.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-dark text-gray-300 py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-sm">© 2026 HotStay International. Proudly made for travelers.</p>
        <div class="flex gap-6 mt-4 md:mt-0">
          <a href="#" class="text-sm hover:text-white transition-colors">Privacy Policy</a>
          <a href="#" class="text-sm hover:text-white transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>