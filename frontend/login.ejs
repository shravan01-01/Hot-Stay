<%- include('./includes/head'); %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-4 font-jakarta">

    <a href="/Hot-Stay" class="absolute top-5 left-5 text-text font-semibold text-sm hover:text-primary transition-colors flex items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <div class="bg-white w-full max-w-md p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
        <div class="text-center mb-6">
            <a href="/Hot-Stay" class="text-2xl font-bold text-primary">HotStay</a>
        </div>

        <h2 class="text-2xl font-bold text-center mb-2">Log in</h2>
        <p class="text-gray-600 text-sm text-center mb-6">Welcome back.</p>

        <form id="loginForm" action="/Validation" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Email</label>
                <input type="email" name="email" placeholder="Email" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <div>
                <label class="block text-xs font-semibold mb-2 text-text">Password</label>
                <input type="password" name="password" placeholder="Password" required
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-text outline-none transition-colors">
            </div>

            <button type="submit" class="w-full bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 rounded-lg transition-colors">
                Continue
            </button>
        </form>

        <div class="flex items-center my-6">
            <div class="flex-1 border-t border-gray-300"></div>
            <span class="px-3 text-xs text-gray-500">or</span>
            <div class="flex-1 border-t border-gray-300"></div>
        </div>

        <div class="space-y-3">
            <button class="w-full flex items-center justify-center gap-3 py-3 border border-text rounded-lg hover:bg-gray-50 transition-colors font-semibold text-sm">
                <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_Logo.svg" width="16" alt="Google">
                Google
            </button>

            <button class="w-full flex items-center justify-center gap-3 py-3 border border-text rounded-lg hover:bg-gray-50 transition-colors font-semibold text-sm">
                <i class="fa-brands fa-apple text-lg"></i>
                Apple
            </button>
        </div>

        <p class="text-center mt-6 text-sm">
            Don't have an account?
            <a href="#" class="text-text font-semibold hover:text-primary transition-colors">Sign up</a>
        </p>
    </div>

    <script>
        // High-speed snappy entrance
        gsap.from(".bg-white", {
            duration: 0.35,
            y: 15,
            opacity: 0,
            ease: "power4.out"
        });

        // Show loading spinner on submit
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            const btn = document.querySelector('button[type="submit"]');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Logging in...';
            btn.disabled = true;
        });
    </script>

</body>
</html>