<%- include('./includes/head'); %>
</head>

<body class="bg-background font-jakarta text-text min-h-screen">
    <header class="h-16 bg-white/95 backdrop-blur-sm border-b border-gray-200 sticky top-0 z-50">
        <div class="w-full px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <%- include('./includes/logo'); %>
                <div class="flex items-center gap-4">
                    <a href="/Hot-Stay/host/dashboard" class="px-4 py-2 bg-primary text-white rounded-md">Dashboard</a>
                    <%- include('./includes/profile icon'); %>
                </div>
            </div>
        </div>
    </header>

    <main class="py-12">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-2xl font-bold mb-6">Host your place</h1>

            <form method="POST" action="/Hot-Stay/host/new" class="space-y-4 bg-white p-6 rounded-lg shadow">
                <div>
                    <label class="block text-sm font-semibold mb-2">Property Title</label>
                    <input name="name" required class="w-full border px-3 py-2 rounded" />
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Location</label>
                    <input name="location" class="w-full border px-3 py-2 rounded" />
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Type</label>
                    <input name="type" class="w-full border px-3 py-2 rounded" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold mb-2">Guests</label>
                        <input name="guests" type="number" min="1" class="w-full border px-3 py-2 rounded" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2">Price (per night)</label>
                        <input name="price" type="number" step="0.01" class="w-full border px-3 py-2 rounded" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2">Images (comma separated URLs)</label>
                    <input name="images" class="w-full border px-3 py-2 rounded" />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2">Categories (comma separated)</label>
                    <input name="categories" class="w-full border px-3 py-2 rounded" />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2">Host Email</label>
                    <input name="hostEmail" type="email" class="w-full border px-3 py-2 rounded" />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2">Description</label>
                    <textarea name="description" rows="5" class="w-full border px-3 py-2 rounded"></textarea>
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="px-6 py-2 bg-secondary text-white rounded">Create listing</button>
                </div>
            </form>
        </div>
    </main>

</body>

</html>
