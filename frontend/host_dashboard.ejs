<%- include('./includes/head'); %>
</head>
<body class="bg-background font-jakarta text-text min-h-screen">
    <header class="h-16 bg-white/95 backdrop-blur-sm border-b border-gray-200 sticky top-0 z-50">
        <div class="w-full px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <%- include('./includes/logo'); %>
                <div class="flex items-center gap-4">
                    <a href="/Hot-Stay/host/new" class="px-4 py-2 bg-primary text-white rounded-md">List new</a>
                    <%- include('./includes/profile icon'); %>
                </div>
            </div>
        </div>
    </header>

    <main class="py-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-2xl font-bold mb-6">Hosted Listings</h1>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if(hotels && hotels.length > 0) { %>
                    <% hotels.forEach(h => { %>
                        <div class="bg-white rounded-lg shadow p-4 border">
                            <div class="h-44 bg-gray-200 rounded overflow-hidden mb-3">
                                <% if(h.images && h.images.length > 0) { %>
                                    <img src="<%= h.images[0] %>" class="w-full h-full object-cover" />
                                <% } %>
                            </div>
                            <h3 class="font-semibold"><%= h.name %></h3>
                            <p class="text-sm text-gray-500"><%= h.location %></p>
                            <p class="mt-2">₹<%= h.price %> / night</p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-12">
                        <p class="text-gray-500">No hosted listings yet.</p>
                        <a href="/Hot-Stay/host/new" class="text-primary font-semibold">Create one</a>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

</body>

</html>
